root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_size = 4
indent_style = tab

[*.py]
indent_size = 4

[*.rs]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{cmd,bat,ps1}]
end_of_line = crlf
