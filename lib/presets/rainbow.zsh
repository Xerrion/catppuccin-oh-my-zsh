# Catppuccin Preset: rainbow
# Every segment gets a unique vibrant background color.
# Powerline arrows between segments. Maximum visual flair.
# Closest to a Powerlevel10k rainbow configuration.

: ${CATPPUCCIN_LAYOUT:="twoline"}
: ${CATPPUCCIN_STYLE:="rainbow"}
: ${CATPPUCCIN_SEPARATOR:="space"}

: ${CATPPUCCIN_SHOW_OS_ICON:="true"}
: ${CATPPUCCIN_SHOW_ARROW:="false"}
: ${CATPPUCCIN_SHOW_STATUS:="true"}
: ${CATPPUCCIN_SHOW_PROMPT_CHAR:="true"}
: ${CATPPUCCIN_SHOW_USER:="true"}
: ${CATPPUCCIN_SHOW_HOST:="ssh"}
: ${CATPPUCCIN_SHOW_CWD:="true"}
: ${CATPPUCCIN_SHOW_GIT:="true"}
: ${CATPPUCCIN_SHOW_TIME:="true"}
: ${CATPPUCCIN_SHOW_VENV:="true"}
: ${CATPPUCCIN_SHOW_PYTHON:="true"}
: ${CATPPUCCIN_SHOW_NODE:="true"}
: ${CATPPUCCIN_SHOW_RUST:="true"}
: ${CATPPUCCIN_SHOW_GO:="true"}
: ${CATPPUCCIN_SHOW_RUBY:="true"}
: ${CATPPUCCIN_SHOW_JAVA:="true"}
: ${CATPPUCCIN_SHOW_PHP:="true"}
: ${CATPPUCCIN_SHOW_K8S:="true"}
: ${CATPPUCCIN_SHOW_JOBS:="true"}
: ${CATPPUCCIN_SHOW_EXEC_TIME:="true"}

: ${CATPPUCCIN_SEGMENTS:="os_icon user host cwd git venv"}
: ${CATPPUCCIN_RSEGMENTS:="status exec_time python node rust go ruby java php k8s jobs time"}

: ${CATPPUCCIN_TRANSIENT_PROMPT:="true"}
: ${CATPPUCCIN_CWD_TRUNCATE:="3"}
: ${CATPPUCCIN_STATUS_MODE:="both"}
: ${CATPPUCCIN_PROMPT_CHAR:="❯"}

# Rainbow uses distinct backgrounds per segment
: ${CATPPUCCIN_BG_OS_ICON:="blue"}
: ${CATPPUCCIN_BG_USER:="mauve"}
: ${CATPPUCCIN_BG_HOST:="pink"}
: ${CATPPUCCIN_BG_CWD:="sapphire"}
: ${CATPPUCCIN_BG_GIT:="teal"}
: ${CATPPUCCIN_BG_VENV:="peach"}
: ${CATPPUCCIN_BG_STATUS:="surface1"}
: ${CATPPUCCIN_BG_TIME:="lavender"}
: ${CATPPUCCIN_BG_PYTHON:="yellow"}
: ${CATPPUCCIN_BG_NODE:="green"}
: ${CATPPUCCIN_BG_RUST:="peach"}
: ${CATPPUCCIN_BG_GO:="sky"}
: ${CATPPUCCIN_BG_RUBY:="red"}
: ${CATPPUCCIN_BG_JAVA:="maroon"}
: ${CATPPUCCIN_BG_PHP:="flamingo"}
: ${CATPPUCCIN_BG_K8S:="blue"}
: ${CATPPUCCIN_BG_JOBS:="rosewater"}
: ${CATPPUCCIN_BG_EXEC_TIME:="yellow"}
